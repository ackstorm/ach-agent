# ach-agent — local/dev environment example. Copy to `.env` and fill in.
# In production these are rendered into the pod by ach-runtime (the operator);
# for local runs you set them yourself. NEVER commit real values.

# Path to the rendered runtime config (CONTRACT.md §2).
# Defaults to /etc/ach-agent/config.json when unset.
ACH_CONFIG_PATH=./tests/config/fixtures/config_cron.json

# opencode engine endpoint + key.
# ACH_API_KEY is an `ek_` bearer — never logged; it is dereferenced only at
# runtime via {env:ACH_API_KEY} in the generated opencode.json.
ACH_BASE_URL=http://localhost:4000
ACH_API_KEY=ek_REPLACE_ME

# Channel credentials — set only the ones your config actually uses.
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=REPLACE_ME
SLACK_BOT_TOKEN=REPLACE_ME
TELEGRAM_BOT_TOKEN=REPLACE_ME
