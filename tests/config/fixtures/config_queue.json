{
  "schemaVersion": "1",
  "agent": {
    "name": "queue-test-agent",
    "namespace": "engineering",
    "generation": 1
  },
  "model": {
    "selected": "codex-1",
    "reasoningEffort": "medium"
  },
  "workDir": "/workspace",
  "startupTimeoutSeconds": 30,
  "governed": true,
  "capability": {
    "type": "ach",
    "ach": {
      "baseUrl": "https://ach.example.com",
      "environment": "production"
    },
    "filter": {
      "exclude": {
        "tools": []
      }
    }
  },
  "limits": {
    "maxConcurrentInvocations": 1,
    "maxInvocationSeconds": 1800,
    "maxQueuedTotal": 100,
    "idempotencyWindowSeconds": 3600,
    "maxSteps": 50,
    "terminalOutputRetries": 1
  },
  "persistence": {
    "enabled": false,
    "mountPath": "/var/lib/ach-agent"
  },
  "health": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "channels": [
    {
      "name": "triage-queue",
      "type": "queue",
      "concurrency": 1,
      "expire": 120,
      "session": {
        "mode": "auto",
        "continuity": "ephemeral",
        "ttlSeconds": 86400
      },
      "queue": {
        "type": "redis",
        "key": "ach:triage",
        "ackMode": "onComplete"
      }
    }
  ]
}
