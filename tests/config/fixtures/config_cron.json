{
  "schemaVersion": "1",
  "agent": {
    "name": "cron-test-agent",
    "namespace": "engineering",
    "generation": 1
  },
  "model": {
    "name": "openai.gpt-5",
    "type": "openai",
    "params": {
      "temperature": 1
    }
  },
  "workDir": "/workspace",
  "startupTimeoutSeconds": 30,
  "governed": true,
  "capability": {
    "type": "ach",
    "ach": {
      "baseUrl": "https://ach.example.com",
      "environment": "production"
    },
    "filter": {
      "exclude": {
        "tools": []
      }
    }
  },
  "limits": {
    "maxConcurrentInvocations": 1,
    "maxInvocationSeconds": 1800,
    "maxQueuedTotal": 100,
    "idempotencyWindowSeconds": 3600,
    "maxSteps": 50,
    "terminalOutputRetries": 1
  },
  "persistence": {
    "enabled": false,
    "mountPath": "/var/lib/ach-agent"
  },
  "health": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "channels": [
    {
      "name": "heartbeat",
      "type": "cron",
      "concurrency": 1,
      "expire": 60,
      "session": {
        "mode": "auto",
        "continuity": "durable",
        "ttlSeconds": 86400
      },
      "cron": {
        "schedule": "* * * * *",
        "timezone": "Europe/Madrid"
      }
    }
  ]
}
