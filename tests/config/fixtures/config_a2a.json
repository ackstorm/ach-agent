{
  "schemaVersion": "1",
  "agent": {
    "name": "a2a-test-agent"
  },
  "model": {
    "name": "openai.gpt-5",
    "type": "openai",
    "params": {
      "temperature": 1
    }
  },
  "engine": {
    "workDir": "/workspace",
    "startupTimeoutSeconds": 30
  },
  "capability": {
    "type": "ach",
    "ach": {
      "baseUrl": "https://ach.example.com",
      "environment": "production"
    },
    "filter": {
      "exclude": {
        "tools": []
      }
    }
  },
  "limits": {
    "maxConcurrentInvocations": 1,
    "maxInvocationSeconds": 1800,
    "maxQueuedTotal": 100,
    "idempotencyWindowSeconds": 3600,
    "maxSteps": 50,
    "terminalOutputRetries": 1
  },
  "persistence": {
    "enabled": false,
    "mountPath": "/var/lib/ach-agent"
  },
  "health": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "channels": [
    {
      "name": "agent-to-agent",
      "type": "a2a",
      "concurrency": 1,
      "a2a": {
        "mode": "async",
        "auth": {
          "header": "x-a2a-custom-api-key",
          "secret": { "file": "/etc/ach-agent/secrets/a2a/key" }
        }
      }
    }
  ]
}
